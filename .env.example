# Copy this file to `.env` and fill in your values. NEVER commit `.env`.

# REQUIRED — private key of the wallet that SIGNS orders (your EOA / signer).
# The SDK derives your Polymarket Deposit Wallet deterministically from this key.
POLYMARKET_PRIVATE_KEY=0xREPLACE_WITH_YOUR_PRIVATE_KEY

# OPTIONAL — pin an existing account wallet (deposit wallet / Poly Safe / Poly Proxy,
# or the signer address itself for EOA trading). Leave blank to use the default
# deterministic Deposit Wallet (signature type 3 / POLY_1271).
# POLYMARKET_WALLET_ADDRESS=0x...

# OPTIONAL — relayer API key, only needed if your wallet still has to be DEPLOYED
# or have trading approvals submitted on-chain. If your wallet already trades on
# polymarket.com, you almost certainly do NOT need these.
# POLYMARKET_RELAYER_API_KEY=
# POLYMARKET_RELAYER_API_KEY_ADDRESS=0x...
